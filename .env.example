# Gmail SMTP credentials for the /api/contact form.
# Use a Gmail App Password (Google Account -> Security -> 2-Step Verification -> App passwords),
# NOT your normal account password (Google rejects plain passwords over SMTP).
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password

# Where contact-form emails are delivered. Optional; defaults to GMAIL_USER.
CONTACT_TO=you@gmail.com
